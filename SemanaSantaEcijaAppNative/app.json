{
  "expo": {
    "name": "SemanaSantaEcijaApp",
    "slug": "semanasantaecijaapp",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4b0082"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4b0082"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {}
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}
